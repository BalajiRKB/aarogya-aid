# Groq — used for the LLM (llama-3.3-70b-versatile). Free tier available at console.groq.com
GROQ_API_KEY=gsk_your-groq-key-here

# OpenAI — used ONLY for text embeddings (Groq has no embeddings API)
# Use text-embedding-3-small, cheapest option (~$0.00002 per 1K tokens)
OPENAI_API_KEY=sk-your-openai-key-here

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
CHROMA_PERSIST_DIR=./chroma_db
SECRET_KEY=your-secret-key-here

# LLM model (Groq)
LLM_MODEL=llama-3.3-70b-versatile

# Embedding model (OpenAI)
EMBEDDING_MODEL=text-embedding-3-small

ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
